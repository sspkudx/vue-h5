{
    "name": "vue-h5",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev:example": "./scripts/build-packages.sh --skip-clean && pnpm -F example-app dev",
        "build:example": "pnpm -F example-app build",
        "build:shared": "pnpm -F @my-app/shared build",
        "build:packages": "./scripts/build-packages.sh",
        "build": "sh ./scripts/build.sh",
        "lint": "eslint \"apps/**/src/**/*.{js,jsx,ts,tsx,vue}\" \"packages/**/src/**/*.{js,jsx,ts,tsx}\" --ext .js,.jsx,.ts,.tsx,.vue",
        "lint:fix": "eslint \"apps/**/src/**/*.{js,jsx,ts,tsx,vue}\" \"packages/**/src/**/*.{js,jsx,ts,tsx}\" --ext .js,.jsx,.ts,.tsx,.vue --fix",
        "lint:example": "pnpm -F example-app lint",
        "lint:style": "stylelint \"**/*.{css,less,vue}\" --config-basedir . --ignore-path .stylelintignore",
        "lint:style:fix": "stylelint \"**/*.{css,less,vue}\" --fix --config-basedir . --ignore-path .stylelintignore",
        "format": "prettier --write \"apps/**/src/**/*.{js,jsx,ts,tsx,vue,css,less,scss}\" \"packages/**/src/**/*.{js,jsx,ts,tsx}\" \"*.{js,jsx,ts,tsx,json,yml,yaml}\"",
        "format:check": "prettier --check \"apps/**/src/**/*.{js,jsx,ts,tsx,vue,css,less,scss}\" \"packages/**/src/**/*.{js,jsx,ts,tsx}\" \"*.{js,jsx,ts,tsx,json,yml,yaml}\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:shared": "pnpm -F @my-app/shared test"
    },
    "dependencies": {
        "@vue/babel-plugin-jsx": "^1.5.0",
        "core-js": "^3.49.0",
        "lodash-es": "^4.18.1",
        "pinia": "^3.0.4",
        "ress": "^5.0.2",
        "vue": "^3.5.38",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@babel/core": "^7.12.0",
        "@mdi/font": "^7.4.47",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/jest": "^29.5.14",
        "@types/lodash-es": "^4.17.12",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "@vue/cli-plugin-babel": "^5.0.9",
        "@vue/cli-plugin-eslint": "^5.0.9",
        "@vue/cli-plugin-router": "^5.0.9",
        "@vue/cli-plugin-typescript": "^5.0.9",
        "@vue/cli-service": "^5.0.9",
        "@vue/eslint-config-typescript": "^11.0.3",
        "babel-loader": "^9.2.1",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^8.10.2",
        "eslint-plugin-prettier": "^4.2.5",
        "eslint-plugin-vue": "^9.33.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "less": "^4.6.6",
        "less-loader": "^12.3.3",
        "postcss": "^8.4.31",
        "postcss-calc": "^9.0.1",
        "postcss-html": "^1.8.1",
        "postcss-px-to-viewport": "^1.1.1",
        "prettier": "^2.8.8",
        "rimraf": "^6.1.3",
        "rollup": "^3.30.0",
        "rollup-plugin-dts": "^6.4.1",
        "style-resources-loader": "^1.5.0",
        "stylelint": "^15.11.0",
        "stylelint-config-prettier": "^8.0.2",
        "stylelint-config-recommended-less": "^3.0.1",
        "stylelint-config-recommended-vue": "^1.6.1",
        "stylelint-config-standard": "^34.0.0",
        "stylelint-less": "^3.0.1",
        "stylelint-order": "^6.0.4",
        "stylelint-prettier": "^3.0.0",
        "ts-jest": "^29.4.11",
        "typescript": "^4.9.5",
        "webpack": "^5.107.2"
    },
    "engines": {
        "node": ">=14.18.0"
    }
}
